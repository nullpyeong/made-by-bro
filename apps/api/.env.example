# apps/api 환경변수 — 실제 값은 .env 에 (커밋 금지). 이 파일은 템플릿.
# 로컬 Docker DB (루트 docker-compose.yml) 기준. 자세히는 ../../SETUP.md
DATABASE_URL="postgresql://madebybro:madebybro@localhost:5432/madebybro?schema=public"
PORT=3000

# 인증(ADR 0011). JWT_SECRET 미설정 시 dev 임시값+경고로 뜨지만 운영 전 반드시 설정.
JWT_SECRET="change-me-in-prod"
JWT_ACCESS_TTL="15m"
# CORS 화이트리스트(쉼표구분). 미설정 시 dev 전체 허용.
# CORS_ORIGIN="http://localhost:5173"

# 계정당 동시 활성 세션(기기) 한도. 초과 시 가장 오래된 세션부터 폐기. 기본 2.
MAX_ACTIVE_SESSIONS=2

# 카카오 OAuth(소셜 로그인). REST_API_KEY 미설정 시 카카오 로그인 비활성.
# KAKAO_REST_API_KEY="..."
# KAKAO_REDIRECT_URI="http://localhost:5173/auth/kakao/callback"
# KAKAO_CLIENT_SECRET=""   # 카카오 보안 설정에서 활성화한 경우만
# 아래 3개는 테스트용 오버라이드(기본값=실제 카카오 엔드포인트, 보통 설정 불필요).
# KAKAO_AUTHORIZE_URL="https://kauth.kakao.com/oauth/authorize"
# KAKAO_TOKEN_URL="https://kauth.kakao.com/oauth/token"
# KAKAO_USERINFO_URL="https://kapi.kakao.com/v2/user/me"

# 결제 웹훅 서명 검증(ADR 0013). 미설정 시 모든 웹훅 거부(fail-closed).
# 헤더명/인코딩은 Toss 실제 서명 사양 확정 후 맞춘다(ADR 0013 유보).
# TOSS_WEBHOOK_SECRET="..."
# TOSS_WEBHOOK_SIG_HEADER="tosspayments-webhook-signature"
# TOSS_WEBHOOK_SIG_ENCODING="base64"   # base64 | hex
